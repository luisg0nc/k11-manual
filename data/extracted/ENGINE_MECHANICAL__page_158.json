  "content_blocks": [
    {
      "block_type": "heading",
      "level": 2,
      "text": "Inspection (Cont'd)"
    },
    {
      "block_type": "heading",
      "level": 3,
      "text": "COMBUSTION CHAMBER REPLACEMENT"
    },
    {
      "block_type": "prose",
      "text": "Usually combustion chambers should not be removed. However, if they show cracks or extensive damage, they should be replaced.",
      "style": "important"
    },
    {
      "block_type": "procedure",
      "id": "combustion_chamber_replacement",
      "title": "Combustion Chamber Replacement",
      "steps": [
        {
          "step": 1,
          "text": "Remove glow plug connecting plate, glow plugs and injection nozzle.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Heat cylinder head in oil to between 150 and 160\u00b0C (302 and 320\u00b0F).",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Remove combustion chamber so that cylinder head will not be damaged.",
          "figure_ref": null,
          "warnings": [],
          "notes": [
            "Be careful not to scratch inside of nozzle hole."
          ]
        },
        {
          "step": 4,
          "text": "Install combustion chamber.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": "4a",
          "text": "Heat cylinder head 150 to 160\u00b0C (302 to 320\u00b0F) in oil.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": "4b",
          "text": "Align combustion chamber knock pin with cylinder head notch, and install it into cylinder head using a plastic-tip hammer.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        }
      ]
    },
    {

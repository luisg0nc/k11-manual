      "steps": [
        {
          "step": 4,
          "text": "Install connecting rod bearings in connecting rods and connecting rod caps.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": [
            "Confirm that correct bearings are used. Refer to \"Inspection\"."
          ]
        },
        {
          "step": 5,
          "text": "Install pistons with connecting rods.",
          "figure_ref": "fig3",
          "warnings": [
            "Be careful not to scratch cylinder wall by connecting rod.",
            "Arrange so that front mark on piston head faces toward front of engine."
          ],
          "notes": [],
          "sub_steps": [
            {
              "sub_step": "a",
              "text": "Install them into corresponding cylinders with Tool.",
              "figure_ref": "fig3"
            },

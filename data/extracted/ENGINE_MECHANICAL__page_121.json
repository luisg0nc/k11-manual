              "torque_spec": {
                "label": "Connecting rod bearing nut",
                "step1": "Tighten to 14 to 16 N\u00b7m (1.4 to 1.6 kg-m, 10 to 12 ft-lb).",
                "step2": "Turn nuts to 45\u00b0 to 50\u00b0 degrees clockwise with an angle wrench."
              }
            }
          ]
        },

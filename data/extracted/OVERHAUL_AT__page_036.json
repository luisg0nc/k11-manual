      "title": "Installation (Cont'd)",
      "steps": [
        {
          "step": 10,
          "text": "Temporarily tighten the valve bolts. Ensure that the engine brake lever is in contact with the ratio sensor bolt.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 11,
          "text": "Press on the valve body to ensure correct location, and tighten the bolts.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 12,
          "text": "Connect the modulator rod. Fit Tool plate as shown. Slacken off the adjuster bolt.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 13,
          "text": "Push the adjuster plate in the direction of the arrow, and tighten the bolt to remove free play. Remove the tool.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        },
        {
          "step": 14,
          "text": "Connect the harness & control cable.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 15,
          "text": "Fit the oil strainer (using a new O ring).",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 16,
          "text": "Fit the oil pan using a new gasket.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 17,
          "text": "Fill with new ATF.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        }
      ]
    },

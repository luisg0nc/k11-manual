  "content_blocks": [
    {
      "block_type": "heading",
      "level": 1,
      "text": "CYLINDER HEAD"
    },
    {
      "block_type": "prose",
      "style": "caution",
      "text": "CAUTION:\n\u2022 After removing timing chain, do not turn crankshaft and camshaft separately, or valves will strike piston heads.\n\u2022 When installing chain tensioner, oil seats, or other sliding parts, lubricate contacting surfaces with new engine oil.\n\u2022 Apply new engine oil to bolt threads and seat surface when installing camshaft sprocket and crankshaft pulley.\n\u2022 When removing oil pump assembly, remove camshaft position sensore (PHASE), then remove timing chain from engine.\n\u2022 Be careful not to damage sensor edges."
    },
    {
      "block_type": "heading",
      "level": 2,
      "text": "Removal"
    },
    {
      "block_type": "procedure",
      "id": "cylinder_head_removal",
      "title": "Cylinder Head Removal",
      "steps": [
        {
          "step": 1,
          "text": "Drain engine coolant from radiator and cylinder block. Be careful not to spill coolant on drive belts.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Remove the alternator and power steering drive belts.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Remove air cleaner.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Remove front right-side wheel.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 5,
          "text": "Remove front and right-side splashguards.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 6,
          "text": "Remove front exhaust tube.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 7,
          "text": "Remove ignition coils.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 8,
          "text": "Remove rocker cover.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": [
            "Loosen bolts in numerical order as shown in figure"
          ]
        },
        {
          "step": 9,
          "text": "Remove all spark plugs.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 10,
          "text": "Set No. 1 piston at T.D.C. on compression stroke.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        }
      ]
    }

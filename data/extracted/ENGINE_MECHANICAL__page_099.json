    {
      "block_type": "procedure",
      "id": "inspection_contd",
      "title": "Inspection (Cont'd)",
      "steps": [
        {
          "step": 4,
          "text": "Heat cylinder head to 110 to 120\u00b0C (230 to 248\u00b0F) and press service valve guide into cylinder head.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": [],
          "specs": [
            {
              "label": "Projection \"L\"",
              "value": "11.5 - 11.7",
              "unit": "mm (0.453 - 0.461 in)",
              "condition": ""
            }
          ]
        },
        {
          "step": 5,
          "text": "Ream valve guide.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": [],
          "specs": [
            {
              "label": "Finished size: Intake & Exhaust",
              "value": "5.500 - 5.515",
              "unit": "mm (0.2165 - 0.2171 in)",
              "condition": ""
            }
          ]
        }
      ]
    },
    {
      "block_type": "heading",
      "level": 2,
      "text": "VALVE SEATS"
    },
    {
      "block_type": "prose",
      "text": "Check valve seats for any evidence of pitting at valve contact surface, and reset or replace if it has worn out excessively.",
      "style": "normal"
    },
    {
      "block_type": "prose",
      "text": "Before repairing valve seats, check valve and valve guide for wear. If they have worn, replace them. Then correct valve seat.",
      "style": "important"
    },
    {
      "block_type": "prose",
      "text": "Cut with both hands to uniform the cutting surface.",
      "style": "important"
    },
    {
      "block_type": "heading",
      "level": 2,
      "text": "REPLACING VALVE SEAT FOR SERVICE PARTS"
    },
    {
      "block_type": "procedure",
      "id": "replacing_valve_seat",
      "title": "Replacing Valve Seat for Service Parts",
      "steps": [
        {
          "step": 1,
          "text": "Bore out old seat until it collapses. The machine depth stop should be set so that boring cannot continue beyond the bottom face of the seat recess in cylinder head.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Ream cylinder head recess.",
          "figure_ref": "fig4",
          "warnings": [],
          "notes": [
            "Reaming should be done in circles concentric to the valve guide center so that valve seat will have the correct fit."
          ],
          "specs_label": "Reaming bore for service valve seat Oversize [0.5 mm (0.020 in)]:",
          "specs": [
            {
              "label": "Intake",
              "value": "29.500 - 29.516",
              "unit": "mm (1.1614 - 1.1620 in)",
              "condition": "Oversize 0.5 mm (0.020 in)"
            },
            {
              "label": "Exhaust",
              "value": "25.500 - 25.516",
              "unit": "mm (1.0039 - 1.0046 in)",
              "condition": "Oversize 0.5 mm (0.020 in)"
            }
          ]
        }
      ]
    },

      "block_type": "procedure",
      "id": "removal",
      "title": "Removal",
      "steps": [
        {
          "step": 1,
          "text": "Remove engine under covers.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Set a suitable transmission jack under the transaxle.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Remove center member.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Remove rear cover.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 5,
          "text": "Drain engine oil.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 6,
          "text": "Remove oil pan bolts.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 7,
          "text": "Remove oil pan using tool as illustrated.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": "7-1",
          "text": "Insert Tool between oil pan and cylinder block.",
          "figure_ref": "fig2",
          "warnings": [
            "Do not drive seal cutter into front or rear oil seal retainer portion, or aluminum mating surfaces will be damaged.",
            "Do not insert screwdriver, or oil pan flange will be deformed."
          ],
          "notes": []
        },
        {
          "step": "7-2",
          "text": "Slide Tool by tapping it with a hammer, and remove oil pan.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        }
      ]
    },
    {
      "block_type": "procedure",
      "id": "installation",
      "title": "Installation",
      "steps": [
        {
          "step": 1,
          "text": "Before installing oil pan, remove all traces of liquid gasket from mating surface using a scraper.",
          "figure_ref": "fig4",
          "warnings": [],
          "notes": [
            "Also remove traces of liquid gasket from mating surface of cylinder block."
          ]
        }
      ]
    },

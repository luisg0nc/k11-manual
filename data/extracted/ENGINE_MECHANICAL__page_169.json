    },
    {
      "block_type": "heading",
      "level": 3,
      "text": "PISTON AND CRANKSHAFT"
    },
    {
      "block_type": "procedure",
      "id": "disassembly_piston_crankshaft",
      "title": "PISTON AND CRANKSHAFT",
      "steps": [
        {
          "step": 1,
          "text": "Place engine on a work stand.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Drain coolant and oil.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Remove timing belt. Refer to \"TIMING BELT\", (EM-5012).",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Remove water pump.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 5,
          "text": "Remove oil pan and oil pump.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 6,
          "text": "Remove cylinder head. Refer to \"CYLINDER HEAD\", (EM-5020).",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 7,
          "text": "Remove pistons with connecting rods.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 8,
          "text": "Remove oil seal retainers front and rear.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 9,
          "text": "Remove piston rings with a tool.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        },
        {
          "step": 10,
          "text": "Remove main bearing caps, crankshaft, and main bearings.",
          "figure_ref": "fig4",
          "warnings": [],
          "notes": [
            "Before removing main bearing caps, measure crankshaft end play. (Refer to cylinder block assembly section.)",
            "Bolts should be loosened in two or three stages and in the order shown.",
            "Place the bearings and the caps in their correct order.",
            "Journal No. 2 and No. 4 bearings have an oil groove.",
            "Bearings caps are numbered from 1 to 5, starting with No. 1 at flywheel side."
          ]
        }
      ]
    }
  ],

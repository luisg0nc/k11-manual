      "title": "Piston Height Selection Procedure (Cont'd)",
      "steps": [
        {
          "step": 5,
          "text": "Install the connecting rod bearing cap and tighten to the specified torque.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 6,
          "text": "Install the dial indicator on the dial support.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 7,
          "text": "Place the indicator/support above the center of calibration piston.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 8,
          "text": "Turn the crankshaft to TDC, and zero out the dial indicator.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 9,
          "text": "Move the indicator/support onto the deck.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 10,
          "text": "Take a precise reading of the difference in level between calibration piston and the deck.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 11,
          "text": "Follow the same procedure for the other cylinders, using the corresponding connecting rods.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {

  "content_blocks": [
    {
      "block_type": "heading",
      "level": 1,
      "text": "REMOVAL AND INSTALLATION"
    },
    {
      "block_type": "heading",
      "level": 2,
      "text": "Transmission Assembly Removal (Cont'd)"
    },
    {
      "block_type": "procedure",
      "id": "removal_contd",
      "title": "Transmission Assembly Removal (Cont'd)",
      "steps": [
        {
          "step": 8,
          "text": "Set the transmission jack on the A/T and engine main units.",
          "figure_ref": null,
          "warnings": [],
          "notes": [
            "When attaching the transmission jack, be careful not to make contact with the drain plug."
          ]
        },
        {
          "step": 9,
          "text": "Remove the engine mount and engine gusset. Refer to section EM, \"Engine Removal and Installation\".",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 10,
          "text": "Remove the dust cover. While rotating the crankshaft, remove the four electromagnetic clutch bolts.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 11,
          "text": "Remove the transaxle bolts.",
          "figure_ref": "fig4",
          "warnings": [],
          "notes": []
        },
        {
          "step": 12,
          "text": "Remove the starter motor. Refer to section EL, \"Starter Motor\".",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 13,
          "text": "Lower the transmission jack and remove the transaxle assembly.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        }
      ]
    },
    {
      "block_type": "heading",
      "level": 2,
      "text": "Installation"
    },
    {
      "block_type": "prose",
      "text": "Perform the following inspections. Assembly is the reverse sequence of disassembly. Tighten bolts to the specified torque.",
      "style": "normal"
    },
    {
      "block_type": "heading",
      "level": 2,
      "text": "Inspection"
    },
    {
      "block_type": "heading",
      "level": 3,
      "text": "Drive Plate Surface Runout Inspection"
    },
    {
      "block_type": "procedure",
      "id": "runout_inspection",
      "title": "Drive Plate Surface Runout Inspection",
      "steps": [
        {
          "step": 1,
          "text": "Attach a dial gauge to the drive plate.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Rotate the crankshaft. Make sure the runout is within the standard value.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        }
      ]
    },
    {
      "block_type": "specs",
      "items": [
        {
          "label": "Runout standard value",
          "value": "0.5 maximum",
          "unit": "mm",
          "condition": "Drive plate surface runout"
        }
      ]
    },
    {
      "block_type": "prose",
      "text": "When the runout is greater than the standard value, replace the drive plate and ring gear assembly.",
      "style": "important"
    },
    {

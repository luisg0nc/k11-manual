      "title": "VALVE OIL SEAL",
      "steps": [
        {
          "step": 1,
          "text": "Remove cylinder head.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": [
            "Refer to \"Timing chain\" procedure."
          ]
        },
        {
          "step": 2,
          "text": "Remove valve spring and valve oil seal.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Apply engine oil to new valve oil seal and install it with Tool.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": [
            "Do not re-use valve oil seals."
          ]
        },
        {
          "step": 4,
          "text": "Ensure seal is located correctly as shown.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        },
        {
          "step": 5,
          "text": "Refit cylinder head.",

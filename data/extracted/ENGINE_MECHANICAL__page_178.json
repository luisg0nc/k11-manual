      "steps": [
        {
          "step": 4,
          "text": "Install connecting rod bearings in connecting rods and connecting rod caps.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 5,
          "text": "Install pistons with connecting rods.",
          "figure_ref": null,
          "warnings": [],
          "notes": [],
          "sub_steps": [
            {
              "sub_step": "a",
              "text": "Install them into corresponding cylinders with Tool.",
              "figure_ref": "fig1",
              "warnings": [
                "Be careful not to scratch cylinder wall by connecting rod."
              ],
              "notes": [
                "Arrange so that piston clover leaf faces toward the oil filter."
              ]
            },
            {
              "sub_step": "b",
              "text": "Install connecting rod caps. Tighten connecting rod cap nuts to the specified torque.",
              "figure_ref": "fig2",
              "warnings": [],
              "notes": [
                "After installation, check piston protrusion. Refer to \"Inspection\" (EM-5042)."
              ]
            }
          ]
        },
        {
          "step": 6,
          "text": "Install rear oil seal retainer.",
          "figure_ref": null,
          "warnings": [],
          "notes": [],
          "sub_steps": [
            {
              "sub_step": "a",
              "text": "Before installing rear oil seal retainer, remove all traces of liquid gasket from mating surface using a scraper.",
              "figure_ref": "fig3",
              "warnings": [],
              "notes": [
                "Also remove traces of liquid gasket from mating surface of cylinder block."
              ]
            },
            {
              "sub_step": "b",
              "text": "Apply a continuous bead of liquid gasket to mating surface of rear oil seal retainer.",
              "figure_ref": "fig4",
              "warnings": [],
              "notes": [
                "Use Genuine Liquid Gasket or equivalent."
              ]
            }
          ]
        }
      ]

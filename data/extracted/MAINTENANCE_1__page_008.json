      "block_type": "procedure",
      "id": "adjust_waterpump_belt_all_models",
      "title": "All models: Adjustment of waterpump drive belt",
      "steps": [
        {
          "step": 1,
          "text": "Remove splash guards.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Slacken tensioner idler locking nut from below.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Move tensioning idler by turning adjusting bolt from below, until desired belt deflection is obtained.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Tighten tensioner idler locking nut.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 5,
          "text": "Install splash guards.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        }
      ]
    },
    {
      "block_type": "procedure",
      "id": "adjust_alternator_belt_no_ps_no_ac",
      "title": "Models without powersteering and without airconditioning: Adjustment of alternator drive belt",
      "steps": [
        {
          "step": 1,
          "text": "Release all three alternator fixing bolts.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Tilt alternator by turning the adjusting bolt until desired belt deflection is obtained.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Tighten the alternator fixing bolts to specified torque.",
          "figure_ref": null,
          "warnings": [],
          "notes": [

      "steps": [
        {
          "step": 1,
          "text": "Inspect drive belts for cracks, fraying, wear or oil adhesion. If necessary, replace with a new one.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Inspect drive belt deflections by pushing on the belt midway between pulleys.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        }
      ]
    },
    {
      "block_type": "prose",
      "text": "Inspect drive belt deflections when the engine is cold. Adjust if belt deflections exceed the limit.",

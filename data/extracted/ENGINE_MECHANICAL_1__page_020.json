    {
      "block_type": "procedure",
      "id": "timing_chain_installation",
      "title": "Installation",
      "steps": [
        {
          "step": 1,
          "text": "Confirm that No. 1 piston is set at T.D.C. on its compression stroke.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Install crankshaft sprocket and lower timing chain.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": [
            "Set timing chain by aligning its mating mark with the one on crankshaft sprocket.",
            "Make sure sprocket's mating mark faces engine front.",
            "The number of links between the alignment marks (silver) are the same for the left and right sides, so either side can be used during alignment with the sprocket."
          ]
        },
        {
          "step": 3,
          "text": "Fit the lower chain tensioner.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Apply liquid gasket to front cover.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        },
        {
          "step": 5,
          "text": "Install front cover.",
          "figure_ref": "fig4",
          "warnings": [],
          "notes": [
            "Check alignment of mating marks on chain and crankshaft sprocket.",
            "Align oil drive spacer with oil pump.",
            "Ensure O-rings are fitted correctly.",
            "Be careful not to damage oil seal when installing front cover."
          ]
        },
        {
          "step": 6,
          "text": "Install engine front mounting.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 7,
          "text": "Install oil strainer.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 8,
          "text": "Install oil pan. Refer to \"Installation\" in \"OIL PAN\".",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 9,
          "text": "Install crankshaft pulley.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 10,
          "text": "Install center member.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        }

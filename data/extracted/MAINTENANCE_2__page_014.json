      "text": "Changing CVT Fluid"
    },
    {
      "block_type": "procedure",
      "id": "proc1",
      "title": "Changing CVT Fluid",
      "steps": [
        {
          "step": 1,
          "text": "Warm up CVT fluid by driving the vehicle for 10 minutes.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Drain CVT fluid from radiator cooler hose (return side) and refill with new CVT fluid at charging pipe when engine running at idle speed.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Refill until new CVT fluid comes out from radiator cooler hose (return side). About 30 to 50% extra fluid will be required for this procedure.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        }
      ]
    },
    {
      "block_type": "specs",
      "items": [
        {
          "label": "Fluid capacity \u2014 Hyper CVT",
          "value": "Approx. 5.0",
          "unit": "l",
          "condition": ""
        }
      ]
    },
    {
      "block_type": "prose",
      "text": "Use genuine NISSAN CVT fluid (NS-1) or exact equivalent.",
      "style": "caution"
    },

      "block_type": "procedure",
      "id": "transmission_removal",
      "title": "Transmission Assembly Removal",
      "steps": [
        {
          "step": 1,
          "text": "Remove battery, fuse box and relay box.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Remove A/T throttle wire from throttle drum.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Separate the connectors of the inhibitor switch, line pressure solenoid, vehicle speed sensor, and speedometer cable.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Separate connecting parts of the selector linkage and control cable.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 5,
          "text": "Remove drive shafts. Refer to section FA, \"Drive Shaft\".",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 6,
          "text": "Drain the transmission fluid",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 7,
          "text": "Remove the oil cooler hoses.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        }
      ]
    }
  ],

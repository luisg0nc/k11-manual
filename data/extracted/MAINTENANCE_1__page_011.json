  "content_blocks": [
    {
      "block_type": "heading",
      "level": 1,
      "text": "ENGINE MAINTENANCE"
    },
    {
      "block_type": "heading",
      "level": 2,
      "text": "Checking Fuel Lines"
    },
    {
      "block_type": "prose",
      "text": "Inspect fuel lines and tank for improper attachment and for leaks, cracks, damage, loose connections, chafing and deterioration.\nIf necessary, repair or replace faulty parts.",
      "style": "normal"
    },
    {
      "block_type": "prose",
      "text": "CAUTION:\nTighten high-pressure rubber hose clamp so that clamp end is 3 mm (0.12 in) from hose end.\nEnsure that screw does not contact adjacent parts.",
      "style": "caution"
    },
    {
      "block_type": "heading",
      "level": 2,
      "text": "Changing Fuel Filter"
    },
    {
      "block_type": "prose",
      "text": "WARNING:\nBefore removing fuel filter, release fuel pressure from fuel line to eliminate danger.",
      "style": "warning"
    },
    {
      "block_type": "procedure",
      "id": "fuel_pressure_release_consult",
      "title": "Fuel Pressure Release (via CONSULT)",
      "steps": [
        {
          "step": 1,
          "text": "Perform \"FUEL PRESSURE RELEASE\" in \"WORK SUPPORT\" mode and release fuel pressure to zero.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Turn ignition switch off.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        }
      ]
    },
    {
      "block_type": "procedure",
      "id": "fuel_pressure_release_manual",
      "title": "Fuel Pressure Release (Manual Method)",
      "steps": [
        {
          "step": 1,
          "text": "Remove fuse for fuel pump.",
          "figure_ref": "fig4",
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Start engine.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "After engine stalls, crank engine two or three times to make sure that fuel pressure is released.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Turn ignition switch off and install fuse for fuel pump.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        }
      ]
    },
    {
      "block_type": "procedure",
      "id": "fuel_filter_change",
      "title": "Fuel Filter Replacement",
      "steps": [
        {
          "step": 5,
          "text": "Loosen fuel hose clamps.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 6,
          "text": "Replace fuel filter.",
          "figure_ref": "fig5",
          "warnings": [],
          "notes": [
            "Be careful not to spill fuel over engine compartment. Place a shop towel to absorb fuel.",
            "Use a high-pressure type fuel filter. Do not use a synthetic resin fuel filter.",
            "When tightening fuel hose clamps, refer to \"Checking Fuel Lines\"."
          ]
        }
      ]
    }
  ],

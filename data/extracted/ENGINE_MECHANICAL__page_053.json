    },
    {
      "block_type": "procedure",
      "id": "main_bearing_clearance",
      "title": "Main Bearing Clearance Measurement",
      "steps": [
        {
          "step": 1,
          "text": "Set main bearings in their proper positions on cylinder block and main bearing cap.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Install main bearing cap to cylinder block. Tighten all bolts in correct order in two or three stages.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Measure inner diameter of each main bearing.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Measure outer diameter of each main journal in crankshaft.",
          "figure_ref": "fig4",
          "warnings": [],
          "notes": []
        },
        {
          "step": 5,
          "text": "Calculate main bearing clearance. Main bearing clearance = Inner dia. - Outer dia.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 6,
          "text": "If it exceeds the limit, replace bearing.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 7,
          "text": "If clearance cannot be adjusted within the standard of any bearing, grind crankshaft journal and use undersized bearing.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        }
      ]
    },
    {
      "block_type": "specs",
      "items": [
        {
          "label": "Main bearing clearance (Standard)",
          "value": "0.022 - 0.038",
          "unit": "mm (0.0009 - 0.0015 in)",
          "condition": "Main bearing clearance = Inner dia. - Outer dia."
        },
        {
          "label": "Main bearing clearance (Limit)",
          "value": "0.064",
          "unit": "mm (0.0025 in)",
          "condition": "Maximum allowable"
        }
      ]
    },

  "content_blocks": [
    {
      "block_type": "heading",
      "level": 1,
      "text": "ENGINE REMOVAL"
    },
    {
      "block_type": "heading",
      "level": 2,
      "text": "Removal (Cont'd)"
    },
    {
      "block_type": "procedure",
      "id": "removal_contd",
      "title": "Removal (Cont'd)",
      "steps": [
        {
          "step": 29,
          "text": "Remove engine harness from harness saddle on engine mounting.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 30,
          "text": "Disconnect two engine temperature sensors.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 31,
          "text": "Remove main earth lead from body.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 32,
          "text": "On power steering equipped models, slacken water pump drive belt. Refer to section MA. Loosen and remove power steering pump fixing bolts. Tie power steering pump onto vehicle body.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 33,
          "text": "Disconnect fuel lines.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 34,
          "text": "Disconnect throttle cable. Disconnect kickdown cable (NCVT).",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 35,
          "text": "Disconnect speedometer cable.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 36,
          "text": "Disconnect carbon canister hoses.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 37,
          "text": "Disconnect brake vacuum hose from brake servo.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 38,
          "text": "On air conditioning equipped models, slacken alternator drive belt. Refer to section MA. Remove alternator. Loosen and remove air conditioning compressor fixing bolts. Tie air conditioning compressor onto vehicle body.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 39,
          "text": "Attach engine slinger brackets to engine. Engine slinger brackets and engine slinger bracket bolts are described in PARTS CATALOG.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        },
        {
          "step": 40,
          "text": "Remove 4 centermember mounting bolts from vehicle body.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 41,
          "text": "Remove centermember from engine.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 42,
          "text": "Attach slingers to engine slinger brackets and use crane to release load from both top engine mountings.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 43,
          "text": "Disconnect or remove engine mountings.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 44,
          "text": "Lower engine onto transmission jack or floor.",
          "figure_ref": "fig4",
          "warnings": [],
          "notes": []
        }
      ]
    },
    {
      "block_type": "heading",
      "level": 2,
      "text": "Installation"
    },
    {
      "block_type": "procedure",
      "id": "installation",
      "title": "Installation",
      "steps": [
        {
          "step": 1,
          "text": "Install top engine mounting brackets and fixing bolts.",
          "figure_ref": "fig5",
          "warnings": [],
          "notes": [
            "Ensure that insulators are positioned on brackets correctly."
          ]
        },
        {
          "step": 2,
          "text": "Carefully move engine onto engine mounting insulators.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        }
      ]
    },
    {

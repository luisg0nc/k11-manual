  "content_blocks": [
    {
      "block_type": "heading",
      "level": 1,
      "text": "OIL PAN"
    },
    {
      "block_type": "procedure",
      "id": "oil_pan_removal",
      "title": "Removal",
      "steps": [
        {
          "step": 1,
          "text": "Remove splashguards for access to oil pan area.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Drain engine oil.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Remove center member.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Remover front exhaust tube.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 5,
          "text": "Remove oil pan bolts.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 6,
          "text": "(1) Insert Tool between cylinder block and oil pan.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": [
            "Be careful not to damage aluminum mating surface.",
            "Do not insert screwdriver, or oil pan flange will be deformed."
          ]
        },
        {
          "step": 7,
          "text": "(2) Slide Tool by tapping its side with a hammer, and remove oil pan.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        }
      ]
    },
    {
      "block_type": "procedure",
      "id": "oil_pan_installation",
      "title": "Installation",
      "steps": [
        {
          "step": 1,
          "text": "Before installing oil pan, remove all traces of liquid gasket from mating surfaces using a scraper.",
          "figure_ref": null,
          "warnings": [],
          "notes": [
            "Also remove traces of liquid gasket from mating surface of cylinder block."
          ]
        },
        {
          "step": 2,
          "text": "Fit new seals as shown. Ensure correct length, front & rear: Length \"l\": Front seal 134 mm (5.28 in) Rear seal 123 mm (4.84 in)",
          "figure_ref": "fig4",
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Apply a continuous bead of liquid gasket to mating surface of oil pan as shown.",
          "figure_ref": "fig5",
          "warnings": [],
          "notes": [
            "Use Genuine Liquid Gasket or equivalent."
          ]
        }
      ]
    },
    {

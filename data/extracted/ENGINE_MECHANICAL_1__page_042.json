      "level": 1,
      "text": "CYLINDER BLOCK"
    },
    {
      "block_type": "prose",
      "text": "When installing moving parts such as bearings and pistons, always apply new, unused engine oil on the contact surfaces.",
      "style": "caution"
    },
    {
      "block_type": "prose",
      "text": "Place disassembled parts such as bearings and bearing caps in correct order and direction.",
      "style": "caution"
    },
    {
      "block_type": "prose",
      "text": "When tightening connecting rod bolts and main bearing cap bolts, apply engine oil to threads and seating surface of nuts.",
      "style": "caution"
    },

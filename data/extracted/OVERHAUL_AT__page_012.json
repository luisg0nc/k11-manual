        }
      ]
    },
    {
      "block_type": "heading",
      "level": 3,
      "text": "\"R\" POSITION."
    },
    {
      "block_type": "heading",
      "level": 4,
      "text": "Reverse."
    },
    {
      "block_type": "prose",
      "text": "The synchroniser sleeve shifts to the left. Power is transmitted through the reverse idler gear and counter gear to the primary pulley.",
      "style": "normal"
    },

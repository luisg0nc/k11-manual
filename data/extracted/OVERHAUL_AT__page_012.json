    {
      "block_type": "heading",
      "level": 3,
      "text": "\"D\" AND \"Ds\" POSITION."
    },
    {
      "block_type": "heading",
      "level": 4,
      "text": "Forward."
    },
    {
      "block_type": "prose",
      "text": "The synchroniser sleeve shifts to the right. Power is transmitted through the hub to the primary (input) pulley.",
      "style": "normal"
    },
    {
      "block_type": "component_location",
      "ref_figure": "fig2",
      "description": "D and Ds Position synchromesh components",
      "callouts": [
        {
          "label": "Power",

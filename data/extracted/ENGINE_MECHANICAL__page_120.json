    {
      "block_type": "procedure",
      "id": "crankshaft_assembly",
      "title": "Crankshaft Assembly",
      "steps": [
        {
          "step": 1,
          "text": "Set main bearings in their proper positions on cylinder block and main bearing cap.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": [
            "Confirm that correct main bearings are used. Refer to \"Inspection\"."
          ]
        },
        {
          "step": 2,
          "text": "Install crankshaft and main bearing beam and tighten bolts as follows: Main bearing beam bolts (1) Tighten to 25 to 30 N\u00b7m (2.5 to 3.1 kg-m, 18 - 22 ft-lb) in order shown. (2) Turn bolts to 60\u00b0 to 65\u00b0 degrees clockwise with an angle wrench in order shown.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": [
            "Prior to tightening bearing cap bolts, place bearing cap in its proper position by shifting crankshaft in the axial direction.",
            "After securing bearing cap bolts, make sure crankshaft turns smoothly by hand."
          ]
        },
        {
          "step": 3,
          "text": "Measure crankshaft end play.",
          "figure_ref": "fig4",
          "warnings": [],
          "notes": [
            "If beyond the limit, replace thrust bearing with a new one."
          ]
        }
      ]
    },

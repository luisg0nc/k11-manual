      "title": "VALVE GUIDE CLEARANCE",
      "steps": [
        {
          "step": 1,
          "text": "Measure valve stem diameter and valve guide inner diameter as illustrated.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        }
      ]
    },
    {
      "block_type": "specs",
      "items": [
        {
          "label": "Standard clearance (valve guide)",
          "value": "0.025 - 0.052",
          "unit": "mm (0.0010 - 0.0020 in)",
          "condition": "Valve stem to valve guide inner diameter"
        }
      ]
    },
    {
      "block_type": "heading",
      "level": 3,
      "text": "VALVE GUIDE REPLACEMENT"
    },
    {
      "block_type": "procedure",
      "id": "valve_guide_replacement",
      "title": "VALVE GUIDE REPLACEMENT",
      "steps": [
        {
          "step": 1,
          "text": "Heat cylinder head in oil to 150 to 160\u00b0C (302 to 320\u00b0F).",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Drive out valve guide using a press or hammer and a suitable tool.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Ream cylinder head valve guide bore.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Heat cylinder head to 150 to 160\u00b0C (302 to 320\u00b0F) and press service valve guide onto cylinder head.",
          "figure_ref": "fig4",
          "warnings": [],
          "notes": []
        }
      ]
    },
    {
      "block_type": "specs",
      "items": [
        {
          "label": "Reaming bore (service part)",
          "value": "13.495 - 13.527",
          "unit": "mm (0.5313 - 0.5326 in)",
          "condition": "Valve guide bore after reaming"
        },
        {
          "label": "Valve guide protrusion \u2014 INTAKE",
          "value": "39",
          "unit": "mm",
          "condition": "From cylinder head surface"
        },
        {
          "label": "Valve guide protrusion \u2014 EXHAUST",
          "value": "35",
          "unit": "mm",
          "condition": "From cylinder head surface"
        }
      ]
    },
    {
      "block_type": "heading",
      "level": 3,
      "text": "VALVE SEATS"
    },
    {
      "block_type": "procedure",
      "id": "valve_seats",
      "title": "VALVE SEATS",
      "steps": [
        {
          "step": 1,
          "text": "Check valve and valve seat for contact. Coat the valve face with prussian red lead. If contact is wrong, correct valve seat. If the valve red lead appears 360\u00b0 around face, the valve stem and face are concentric. If not, repair or replace valve.",
          "figure_ref": "fig5",
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Check valve seats for pitting at contact surface. Resurface or replace if excessively worn. Correct valve seat surface.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        }
      ]
    },
    {
      "block_type": "prose",
      "text": "When repairing valve seat, check valve and valve guide for wear beforehand. If worn, replace them. Then correct valve seat.",
      "style": "important"
    }
  ],

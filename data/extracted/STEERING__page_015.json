      "steps": [
        {
          "step": 1,
          "text": "When steering wheel can not be rotated smoothly, check the steering column for the following matters and replace damaged parts.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "a. Check column bearings for damage or unevenness. Lubricate with recommended multi-purpose grease or replace steering column as an assembly, if necessary.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "b. Check jacket tube for deformation or breakage. Replace if necessary.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "When the vehicle is involved in a light collision, check column length \"L\". If it is not within specification, replace steering column as an assembly.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        }
      ]
    },

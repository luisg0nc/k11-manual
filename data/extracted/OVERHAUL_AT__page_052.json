    {
      "block_type": "flowchart",
      "title": "Self Diagnosis Items (without using CONSULT)",
      "nodes": [
        {
          "id": "n1",
          "type": "start",
          "text": "Start self diagnosis"
        },
        {
          "id": "n2",
          "type": "action",
          "text": "Park vehicle on a flat surface"
        },
        {
          "id": "n3",
          "type": "action",
          "text": "A\nRelease accelerator pedal (accelerator switch and accelerator position switch are \"ON\") and move selector lever to \"D\" range"
        },
        {
          "id": "n4",
          "type": "action",
          "text": "Turn ignition switch on (do not start engine)"
        },
        {
          "id": "n5",
          "type": "decision",
          "text": "Does N-CVT warning lamp light?"
        },
        {
          "id": "n6",
          "type": "reference",
          "text": "Go to N-CVT warning lamp circuit inspection"
        },
        {
          "id": "n7",
          "type": "action",
          "text": "B\nDepress brake pedal (stop lamp switch goes \"ON\" and fully depress accelerator pedal (accelerator switch and accelerator position switch go \"OFF\") Move selector lever in following order:\nD \u2192 Ds \u2192 D \u2192 N \u2192 R \u2192 P"
        },
        {
          "id": "n8",
          "type": "action",
          "text": "C\nRelease accelerator pedal (accelerator switch and accelerator position switch go \"ON\") and start the engine"
        },
        {
          "id": "n9",
          "type": "action",
          "text": "Count number of N-CVT warning lamp blinks. Refer to \"Self-diagnosis results\" on next page"
        },
        {
          "id": "n10",
          "type": "terminal",
          "text": "End self diagnosis procedure"
        }
      ],

    },
    {
      "block_type": "prose",
      "text": "Check fluid level",
      "style": "normal"
    },
    {
      "block_type": "prose",
      "text": "Fluid level should be checked using \"HOT\" range on dipstick at fluid temperatures of 50 to 80\u00b0C (122 to 176\u00b0F) or using \"COLD\" range on dipstick at fluid temperature of 0 to 30\u00b0C (32 to 86\u00b0F).",
      "style": "normal"
    },
    {
      "block_type": "prose",
      "text": "Do not overfill.",
      "style": "caution"
    },
    {
      "block_type": "prose",
      "text": "Recommended fluid is Automatic Transmission Fluid \"DEXRON\u2122\" type.",
      "style": "caution"
    },

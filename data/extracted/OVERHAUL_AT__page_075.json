    },
    {
      "block_type": "heading",
      "level": 2,
      "text": "Faulty Select Operation"
    },
    {
      "block_type": "prose",
      "text": "Symptom:\n\u2022 Selector lever cannot be moved\n\u2022 Selector lever movement is difficult",
      "style": "normal"
    },
    {
      "block_type": "prose",
      "text": "Diagnosis item:\n\u2022 Brush holder is faulty\n\u2022 Lever and linkage are faulty\n\u2022 Electromagnetic clutch is faulty",
      "style": "normal"
    },
    {
      "block_type": "heading",
      "level": 3,
      "text": "CHECK PROCEDURE"
    },
    {
      "block_type": "flowchart",
      "title": "Faulty Select Operation \u2014 Check Procedure",
      "nodes": [
        {
          "id": "n1",
          "type": "action",
          "text": "Check brush holder circuit (Refer to \"ON-VEHICLE SERVICE\")"
        },
        {
          "id": "n2",
          "type": "terminal",
          "text": "Repair or replace brush holder, harness or connector"
        },
        {
          "id": "n3",
          "type": "action",
          "text": "Check selector lever and control linkage (Refer to \"ON-VEHICLE SERVICE\")"
        },
        {
          "id": "n4",
          "type": "terminal",
          "text": "Adjust or replace selector lever or control linkage"
        },
        {
          "id": "n5",
          "type": "action",
          "text": "Check inhibitor switch circuit"
        },
        {
          "id": "n6",
          "type": "terminal",
          "text": "Adjust or replace inhibitor switch\nRepair or replace harness or connector"
        },
        {
          "id": "n7",
          "type": "action",
          "text": "Operate select lever after engine is stopped (operation is possible but with difficulty)"
        },
        {
          "id": "n8",
          "type": "terminal",
          "text": "Check or repair N-CVT control unit\n\u2022 Select position mechanism"
        },
        {
          "id": "n9",
          "type": "decision",
          "text": "Does engine crank and start in \"N\" range?"
        },
        {
          "id": "n10",
          "type": "terminal",
          "text": "Replace electromagnetic clutch"
        }

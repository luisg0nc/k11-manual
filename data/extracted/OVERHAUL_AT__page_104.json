  "content_blocks": [
    {
      "block_type": "heading",
      "level": 1,
      "text": "REPAIR FOR COMPONENT PARTS \u2014 Secondary Pulley Assembly"
    },
    {
      "block_type": "procedure",
      "id": "disassembly",
      "title": "Disassembly",
      "steps": [
        {
          "step": 1,
          "text": "Fit the pulley to Tool and fit to a vice.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Remove and discard the lock nut.",
          "figure_ref": null,
          "warnings": [
            "Do not use an air wrench to loosen the lock nut, internal damage may occur."
          ],
          "notes": []
        },
        {
          "step": 3,
          "text": "Press out the bearing as shown.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": [
            "The pulley cannot be disassembled."
          ]
        }
      ]
    },
    {
      "block_type": "heading",
      "level": 2,
      "text": "Inspection"
    },
    {
      "block_type": "prose",
      "text": "Check the bearing for wear, scoring, seizure or noisy operation.",
      "style": "normal"
    },
    {
      "block_type": "prose",
      "text": "Check the gear for broken or worn teeth. Inspect the bearing surface contact area for damage.",
      "style": "normal"
    },
    {
      "block_type": "prose",
      "text": "Replace parts as necessary.",
      "style": "normal"
    },
    {
      "block_type": "procedure",
      "id": "assembly",
      "title": "Assembly",
      "steps": [
        {
          "step": 1,
          "text": "Press the reduction gear into the pulley.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Press the bearing on to the pulley.",
          "figure_ref": "fig4",
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Fit and tighten a new lock nut.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Stake the lock nut after tightening.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        }
      ]
    },
    {

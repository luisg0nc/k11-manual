      "block_type": "heading",
      "level": 2,
      "text": "Changing Engine Oil"
    },
    {
      "block_type": "prose",
      "text": "WARNING: Be careful not to burn yourself, as the engine oil is hot.",
      "style": "warning"
    },
    {
      "block_type": "procedure",
      "id": "proc_engine_oil_change",
      "title": "Changing Engine Oil",
      "steps": [
        {
          "step": 1,
          "text": "Warm up engine, and check for oil leakage from engine components.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Remove drain plug and oil filler cap.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Drain oil and refill with new engine oil.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Check oil level.",
          "figure_ref": "fig5",
          "warnings": [],
          "notes": []
        },
        {
          "step": 5,
          "text": "Start engine and check area around drain plug and oil filter for oil leakage.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 6,
          "text": "Run engine for a few minutes, then turn it off. After several minutes, check oil level.",
          "figure_ref": "fig5",
          "warnings": [],
          "notes": []
        }
      ]
    },

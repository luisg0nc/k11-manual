    },
    {
      "block_type": "heading",
      "level": 2,
      "text": "VALVE DIMENSIONS"
    },
    {
      "block_type": "prose",
      "text": "Check dimensions in each valve. For dimensions, refer to S.D.S.",
      "style": "normal"
    },
    {

    {
      "block_type": "procedure",
      "id": "valve_seat_inspection",
      "title": "Valve Seat Inspection (Cont'd)",
      "steps": [
        {
          "step": 3,
          "text": "Heat cylinder head to 110 to 120\u00b0C (230 to 248\u00b0F).",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Press fit valve seat until it seats on the bottom.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 5,
          "text": "Cut or grind valve seat using suitable tool at the specified dimensions as shown in S.D.S.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 6,
          "text": "After cutting, lap valve seat with abrasive compound.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 7,
          "text": "Check valve seating condition.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        }
      ]
    },
    {
      "block_type": "specs",
      "items": [
        {

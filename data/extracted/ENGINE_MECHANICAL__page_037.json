          "value": "45\u00b015' - 45\u00b045'",
          "unit": "deg.",
          "condition": null
        },
        {
          "label": "Contacting width \"W\" - Intake",
          "value": "1.34 - 1.63",
          "unit": "mm (0.0528 - 0.0642 in)",
          "condition": null

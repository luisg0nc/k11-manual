    {
      "block_type": "heading",
      "level": 1,
      "text": "TIMING CHAIN"
    },
    {
      "block_type": "prose",
      "text": "After removing timing chain, do not turn crankshaft and camshaft separately, or valves will strike piston heads.",
      "style": "caution"
    },
    {
      "block_type": "heading",
      "level": 2,
      "text": "Removal"
    },
    {
      "block_type": "procedure",
      "id": "timing_chain_removal",
      "title": "Removal",
      "steps": [
        {
          "step": 1,
          "text": "Drain engine coolant from radiator and cylinder block. Be careful not to spill coolant on drive belts.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Remove the alternator and power steering drive belts.",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Remove air cleaner.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Remove front right-side wheel.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 5,
          "text": "Remove front and right-side splashguards.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 6,
          "text": "Remove front exhaust tube.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 7,
          "text": "Remove rocker cover.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 8,
          "text": "Remove distributor cap.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 9,
          "text": "Remove all spark plugs.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 10,
          "text": "Set No. 1 piston at T.D.C. on compression stroke.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": [
            "Make sure No. 1 cylinder is at T.D.C. by looking at distributor rotor position."
          ]
        },
        {
          "step": 11,
          "text": "Remove distributor.",
          "figure_ref": "fig4",
          "warnings": [],
          "notes": []
        },
        {
          "step": 12,
          "text": "Remove cam sprocket cover.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        }
      ]
    }
  ],

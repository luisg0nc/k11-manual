    },
    {
      "block_type": "heading",
      "level": 2,
      "text": "Engine Races When Driving"
    },
    {
      "block_type": "prose",
      "text": "Symptom: The engine races when driving",
      "style": "normal"
    },
    {
      "block_type": "prose",
      "text": "Diagnosis item: Inhibitor switch is faulty; Manual control linkage adjustment or control linkage is faulty; Control valve is faulty; N-CVT control unit power supply or N-CVT control unit is faulty; Belt slipping (A loud noise that sounds like rubbing metal objects); Electromagnetic clutch is faulty",
      "style": "normal"
    },
    {
      "block_type": "heading",
      "level": 3,
      "text": "CHECK PROCEDURE"
    },
    {
      "block_type": "flowchart",
      "title": "Engine Races When Driving \u2014 Check Procedure",
      "nodes": [
        {
          "id": "n1",
          "type": "action",
          "text": "Perform self diagnosis"
        },
        {
          "id": "n2",
          "type": "terminal",
          "text": "Inspect and repair based on trouble code. When O.K. code or trouble code is not output, check N-CVT control unit."
        },
        {
          "id": "n3",
          "type": "decision",
          "text": "Can the symptom be reproduced?"
        },
        {
          "id": "n4",
          "type": "terminal",
          "text": "Cannot be reproduced easily"
        },
        {
          "id": "n5",
          "type": "action",
          "text": "Drive the vehicle while \"CLUTCH CURRENT\" is displayed on CONSULT screen"
        },
        {
          "id": "n6",
          "type": "decision",
          "text": "When the engine speed is increased, does the clutch current flow?"
        },
        {
          "id": "n7",
          "type": "action",
          "text": "Check control linkage"
        },
        {
          "id": "n8",
          "type": "terminal",
          "text": "Adjust or replace selector arm or control linkage"
        },
        {
          "id": "n9",
          "type": "action",
          "text": "Check inhibitor switch circuit"
        },
        {
          "id": "n10",
          "type": "terminal",
          "text": "Repair or replace inhibitor switch harness or connector"
        },
        {
          "id": "n11",
          "type": "action",
          "text": "Check electromagnetic clutch circuit"
        },
        {
          "id": "n12",
          "type": "terminal",
          "text": "Repair or replace electromagnetic clutch main unit, brush holder or harness."
        },
        {
          "id": "n13",
          "type": "action",
          "text": "Replace N-CVT control unit"
        },
        {
          "id": "n14",
          "type": "decision",
          "text": "Does vibration or shock occur after the engine speed is increased?"
        },
        {
          "id": "n15",
          "type": "terminal",
          "text": "Replace electromagnetic clutch"
        },
        {
          "id": "n16",
          "type": "action",
          "text": "Check or repair main unit: 1. Oil pump 2. Control valve 3. Belt and pulley mechanism"
        }

  "content_blocks": [
    {
      "block_type": "heading",
      "level": 1,
      "text": "ENGINE MAINTENANCE"
    },
    {
      "block_type": "heading",
      "level": 2,
      "text": "Changing Engine Coolant"
    },
    {
      "block_type": "prose",
      "text": "WARNING: To avoid being scalded, never change the coolant when the engine is hot.",
      "style": "warning"
    },
    {
      "block_type": "procedure",
      "id": "coolant_change",
      "title": "Changing Engine Coolant",
      "steps": [
        {
          "step": 1,
          "text": "Turn heater \"TEMP\" control all the way to \"HOT\".",
          "figure_ref": "fig1",
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Remove radiator cap.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Disconnect lower radiator hose to drain coolant.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Remove reservoir tank, drain coolant, then clean reservoir tank. Re-install it temporarily.",
          "figure_ref": null,
          "warnings": [],
          "notes": [
            "Be careful not to allow coolant to contact drive belts."
          ]
        },
        {
          "step": 5,
          "text": "Connect lower radiator hose.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 6,
          "text": "Fill radiator with water up to the radiator inlet. Fill reservoir tank with water up to its \"MAX\" line.",
          "figure_ref": "fig4",
          "warnings": [],
          "notes": []
        },
        {
          "step": 7,
          "text": "While keeping the radiator cap open, warm up the engine. Confirm thermostat is open by touching the radiator upper hose. Race engine 2 or 3 times under no-load.",
          "figure_ref": null,
          "warnings": [],
          "notes": [
            "Make sure that airconditioner switch is \"OFF\"."
          ]
        },
        {
          "step": 8,
          "text": "Stop the engine and wait until it cools down.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 9,
          "text": "Repeat steps 3 through 8 until clear water begins to drain from radiator.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 10,
          "text": "Reinstall reservoir tank.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 11,
          "text": "Fill radiator and reservoir tank with coolant up to specified level following steps 5 through 7.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 12,
          "text": "When air is released from the engine and the coolant level in the radiator has lowered, fill radiator up to the inlet.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 13,
          "text": "After the engine has cooled down, fill the reservoir with coolant up to its \"MAX\" line.",
          "figure_ref": "fig5",
          "warnings": [],
          "notes": []
        },
        {
          "step": 14,
          "text": "Start the engine and bring engine speed up to 3,000 rpm. Confirm that water flowing through the heater core is not audible at instrument panel lower side. If it is audible, repeat steps 11 through 13.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        }
      ]
    }
  ],

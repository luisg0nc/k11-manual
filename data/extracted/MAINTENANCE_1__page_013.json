      "title": "Changing Oil Filter",
      "steps": [
        {
          "step": 1,
          "text": "Remove oil filter with Tool.",
          "figure_ref": "fig1",
          "warnings": [
            "Be careful not to burn yourself, as the engine and the engine oil are hot."
          ],
          "notes": []
        },
        {
          "step": 2,
          "text": "Before installing new oil filter, clean the oil filter mounting surface on cylinder block, and coat the rubber seal of oil filter with a little engine oil.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Screw in the oil filter until a slight resistance is felt, then tighten for a further 2/3 of a turn.",
          "figure_ref": "fig3",
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Add engine oil.",
          "figure_ref": null,
          "warnings": [],
          "notes": [
            "Refer to Changing Engine Oil."
          ]
        }
      ]
    },
    {
      "block_type": "heading",
      "level": 2,
      "text": "Checking and Changing Spark Plugs"
    },
    {
      "block_type": "procedure",
      "id": "checking_changing_spark_plugs",
      "title": "Checking and Changing Spark Plugs",
      "steps": [
        {
          "step": 1,
          "text": "Disconnect ignition leads from spark plugs at boot. Do not pull on the lead.",
          "figure_ref": "fig4",
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "Remove spark plugs with spark plug wrench.",
          "figure_ref": "fig5",
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "Clean plugs in sand blast cleaner.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Check insulator for cracks or chips, gasket for damage or deterioration and electrode for wear and burning. If excessively worn, replace with new spark plugs.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        }
      ]

      "title": "CAMSHAFT CAM HEIGHT",
      "steps": [
        {
          "step": 1,
          "text": "Measure camshaft cam height. Standard cam height: Intake & Exhaust \u2014 CG10DE: 38.005 - 38.195 mm (1.4963 - 1.5037 in); CG13DE: 39.880 - 40.070 mm (1.5701 - 1.5776 in). Cam wear limit: Intake & Exhaust \u2014 0.20 mm (0.0079 in).",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "If wear is beyond the limit, replace camshaft.",
          "figure_ref": null,
          "warnings": [],
          "notes": []
        }
      ]
    },
    {
      "block_type": "specs",
      "items": [
        {
          "label": "Standard cam height \u2014 CG10DE (Intake & Exhaust)",
          "value": "38.005 - 38.195",
          "unit": "mm (1.4963 - 1.5037 in)",
          "condition": ""
        },
        {
          "label": "Standard cam height \u2014 CG13DE (Intake & Exhaust)",
          "value": "39.880 - 40.070",
          "unit": "mm (1.5701 - 1.5776 in)",
          "condition": ""
        },
        {
          "label": "Cam wear limit (Intake & Exhaust)",
          "value": "0.20",
          "unit": "mm (0.0079 in)",
          "condition": ""
        }
      ]
    },

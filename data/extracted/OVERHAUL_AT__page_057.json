    {
      "block_type": "flowchart",
      "title": "Accelerator and accelerator position switch circuit check",
      "nodes": [
        {
          "id": "n1",
          "type": "action",
          "text": "Check accelerator switch and accelerator position switch. Refer to \"Electrical component inspection\""
        },
        {
          "id": "n1_ng",
          "type": "terminal",
          "text": "Repair or replace accelerator switch or accelerator position switch"
        },
        {
          "id": "n2",
          "type": "action",
          "text": "Check input signal\n1. Turn ignition switch \"ON\"\n2. Select \"DATA MONITOR\"\n   Check accelerator switch:\n   \u2022 Check that \"ACCEL SW\" goes \"OFF\" and \"ON\" when accelerator pedal is depressed and released\n   Check accelerator position switch:\n   \u2022 Check that \"THRTL OPEN SW\" goes \"OFF\" and \"ON\" when accelerator pedal is depressed more than 30 mm\n   \u2014 OR \u2014\n   Check accelerator switch:\n   \u2022 Check voltage between N-CVT control unit terminal #6 and ground while accelerator pedal is depressed and released\n   [Table: Depressed = Battery voltage; Released = 0V]\n   Check accelerator position switch:\n   \u2022 Check voltage between N-CVT control unit terminal #15 and ground while accelerator pedal is depressed more than 30 mm and released\n   [Table: Depressed >30 mm = Battery voltage; Released = 0V]"
        },
        {
          "id": "n2_ng",
          "type": "terminal",
          "text": "Repair harness connector between accelerator switch or accelerator position switch and N-CVT control unit terminal"
        },
        {
          "id": "n3",
          "type": "action",
          "text": "Perform self diagnosis after test drive"
        },
        {
          "id": "n3_ng",
          "type": "terminal",
          "text": "1. Check N-CVT Control unit I/O signal\n2. Re-check N-CVT control unit pin terminals for damage or incorrect connection of control unit harness connector"
        },
        {
          "id": "n4",
          "type": "terminal",
          "text": "Inspection END"
        }
      ],

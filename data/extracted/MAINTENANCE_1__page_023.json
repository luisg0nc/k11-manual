      "text": "Checking Seat Belts, Buckles, Retractors, Anchors and Adjusters"
    },
    {
      "block_type": "procedure",
      "id": "seat_belt_check",
      "title": "Checking Seat Belts, Buckles, Retractors, Anchors and Adjusters",
      "steps": [
        {
          "step": 1,
          "text": "If the vehicle has been involved in a collision or has been overturned, replace all seat belt assemblies, regardless of nature of accident.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 2,
          "text": "If the condition of any component of a seat belt is questionable, do not have seat belt repaired, but replaced as a belt assembly.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 3,
          "text": "If webbing is cut, frayed, or damaged, replace belt assembly.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 4,
          "text": "Do not spill drinks, oil, etc. on inner lap belt buckle. Never oil tongue and buckle.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        },
        {
          "step": 5,
          "text": "Use a NISSAN genuine seat belt assembly.",
          "figure_ref": "fig2",
          "warnings": [],
          "notes": []
        }
      ]
    },
